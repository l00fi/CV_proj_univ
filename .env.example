# Copy to .env and fill in secrets:
#   cp .env.example .env
#
# Used by docker compose (env_file + variable substitution). Kaggle credentials
# are required inside the poker-yolo container for train/validate/infer on Kaggle data.

# --- Kaggle (inside Docker training container) ---
KAGGLE_USERNAME=
KAGGLE_KEY=
KAGGLE_CONFIG_DIR=./.kaggle

# --- MLflow ---
# Inside Docker (poker-yolo container): use service name mlflow
MLFLOW_TRACKING_URI=http://mlflow:5000
# For uv run on the host / browser on Windows, use instead:
# MLFLOW_TRACKING_URI=http://localhost:5000

# --- Observability ---
PROMETHEUS_PUSHGATEWAY_URL=http://pushgateway:9091
# For uv run on the host (Pushgateway must be up: docker compose --profile observability up -d):
# PROMETHEUS_PUSHGATEWAY_URL=http://localhost:9091
REPORTS_BASE_URL=http://localhost:8088

# --- GPU / device ---
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility
POKER_YOLO_DEVICE=
# Training resource cap (0–1]: GPU VRAM + power; RAM via mem_limit below
POKER_YOLO_GPU_RESOURCE_FRACTION=
# Docker hard RAM cap for poker-yolo (e.g. 12g ≈ 80% of 16 GB). run_full_train.ps1 sets this automatically.
POKER_YOLO_MEM_LIMIT=
REQUIRE_CUDA=0

# --- Grafana ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_THEME=dark

# --- Host ports ---
MLFLOW_PORT=5000
GRAFANA_PORT=3001
PROMETHEUS_PORT=9090
PUSHGATEWAY_PORT=9091
REPORT_SERVER_PORT=8088
